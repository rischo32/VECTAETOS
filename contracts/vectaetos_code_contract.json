{
  "version": "0.1.4",
  "name": "vectaetos_code_contract",
  "status": "fundamental_repository_perimeter",
  "layer": "external_repository_perimeter",
  "purpose": "Ontological behavior contract for VECTAETOS Python code and repository perimeter tooling.",
  "authority": "none",
  "canonical": false,
  "enforcement_semantics": "Repository perimeter tools may emit findings or fail CI by exit code where explicitly allowed, but this is never truth validation, deployment validation, ontology validation, or authority over VECTAETOS.",
  "not_a_security_audit": true,
  "not_an_integrity_audit": true,
  "not_a_deployment_validation": true,
  "not_a_truth_validation": true,
  "not_an_ontology_validator": true,
  "diagnostics_are_advisory": true,
  "canonical_sentence": "Code may implement repository behavior, but must not attach agency, optimization, truth authority, or decision power to VECTAETOS.",
  "global_invariants": [
    "No code role may define VECTAETOS truth.",
    "No code role may optimize Phi.",
    "No code role may modify Phi.",
    "No code role may modify K(Phi).",
    "No code role may modify kappa.",
    "No code role may redefine QE.",
    "No code role may select trajectories as authoritative truth.",
    "No code role may claim deployment validity.",
    "No code role may claim empirical safety.",
    "No diagnostic output may become an ontology verdict.",
    "No audit layer may become control.",
    "No language layer may become truth authority."
  ],
  "selection_function_semantics": "When allow_selection_functions is true, it only permits local implementation choices such as sorting findings, selecting highest severity diagnostics, bounded numeric clamping, or deterministic report ordering. It never permits trajectory selection, truth ranking, recommendation authority, or optimization of Phi.",
  "protected_ontology_names": [
    "PHI",
    "Phi",
    "phi",
    "Φ",
    "K",
    "K_PHI",
    "KPhi",
    "K(Phi)",
    "K(Φ)",
    "KAPPA",
    "kappa",
    "κ",
    "QE"
  ],
  "protected_ontology_assignment_policy": {
    "meaning": "Protected ontology identifiers must not be assigned, mutated, rebound, monkey-patched, or redefined in roles where protect_ontology_assignments is true.",
    "diagnostic_semantics": "A protected-name assignment finding is a repository behavior signal, not an ontological verdict.",
    "allowed_exceptions": [
      "test fixtures where role protect_ontology_assignments is false",
      "documentation examples that are not executable code",
      "explicitly marked historical legacy material under legacy_vortex constraints"
    ]
  },
  "forbidden_semantic_fragments": [
    "decide",
    "decision",
    "recommend",
    "optimize",
    "optimizer",
    "optimization",
    "reward",
    "policy_update",
    "best_trajectory",
    "select_best",
    "rank_truth",
    "rank_trajectories",
    "truth_authority",
    "deployment_valid",
    "empirical_safety",
    "argmax",
    "argmin"
  ],
  "dynamic_execution_calls": [
    "eval",
    "exec",
    "compile",
    "__import__"
  ],
  "diagnostic_severity_policy": {
    "warning": "Possible semantic drift or suspicious formulation. Human review required.",
    "error": "Repository perimeter hard violation where the role contract explicitly forbids the behavior. This is still not truth validation.",
    "information": "Descriptive local signal with no blocking semantics."
  },
