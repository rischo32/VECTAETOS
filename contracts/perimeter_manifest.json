{
  "schema_version": "0.1.0",
  "manifest_name": "vectaetos_perimeter_manifest",
  "status": "active_manifest_candidate",
  "location": "guards/perimeter_manifest.json",
  "role": "deterministic guard command registry",
  "runner_policy": {
    "runner_has_semantic_authority": false,
    "runner_may_modify_files": false,
    "runner_may_suppress_findings": false,
    "runner_may_execute_only_manifest_commands": true,
    "guard_order_is_deterministic": true
  },
  "variables": {
    "ROOT": ".",
    "BASE_SHA": "${BASE_SHA}",
    "HEAD_SHA": "${HEAD_SHA}",
    "PYTHON": "python3",
    "CODE_CONTRACT": "contracts/vectaetos_code_contract.json",
    "VECTOR_DRIFT_FAIL_AT": "0.70"
  },
  "exit_policy": {
    "guard_exit_0": "ok",
    "guard_exit_1": "finding_or_policy_failure",
    "guard_exit_2": "execution_or_configuration_error",
    "runner_exit_0": "all_required_guards_ok",
    "runner_exit_1": "one_or_more_required_guards_reported_findings",
    "runner_exit_2": "one_or_more_required_guards_failed_to_execute",
    "runner_exit_3": "manifest_or_runner_error"
  },
  "profiles": {
    "report": {
      "description": "non-blocking local visibility profile",
      "default_exit_mapping": {
        "0": "ok",
        "1": "finding",
        "2": "error"
      }
    },
    "ci": {
      "description": "blocking repository perimeter profile",
      "default_exit_mapping": {
        "0": "ok",
        "1": "finding",
        "2": "error"
      }
    }
  },
  "guards": [
    {
      "id": "GUARD-01",
      "name": "canonical_ontology_guard",
      "path": "guards/canonical_ontology_guard.py",
      "level": 0,
      "class": "canonical_repository_boundary",
      "active": true,
      "required": true,
      "needs_git_diff": true,
      "needs_contract": false,
      "command_templates": {
        "report": [
          "${PYTHON}",
          "guards/canonical_ontology_guard.py",
          "--base",
          "${BASE_SHA}",
          "--head",
          "${HEAD_SHA}",
          "--mode",
          "report"
        ],
        "ci": [
          "${PYTHON}",
          "guards/canonical_ontology_guard.py",
          "--base",
          "${BASE_SHA}",
          "--head",
          "${HEAD_SHA}",
          "--mode",
          "strict"
        ]
      },
      "exit_mapping": {
        "0": "ok",
        "1": "finding",
        "2": "error"
      }
    },
    {
      "id": "GUARD-02",
