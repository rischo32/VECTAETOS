            "id": "GUARD-01",
            "name": "canonical_ontology_guard",
            "path": "guards/canonical_ontology_guard.py",
            "level": 0,
            "class": "canonical_repository_boundary",
            "active": true,
            "required": false,
            "report_first": true,
            "needs_git_diff": true,
            "needs_contract": false,
            "notes": "Diff-based guard. BASE_SHA and HEAD_SHA default to HEAD~1/HEAD for local report visibility and should be overridden by CI.",
            "command_templates": {
                "report": [
                    "${PYTHON}",
                    "guards/canonical_ontology_guard.py",
                    "--base",
                    "${BASE_SHA}",
                    "--head",
                    "${HEAD_SHA}",
                    "--mode",
                    "report"
                ],
                "ci": [
                    "${PYTHON}",
                    "guards/canonical_ontology_guard.py",
                    "--base",
                    "${BASE_SHA}",
                    "--head",
                    "${HEAD_SHA}",
                    "--mode",
                    "strict"
                ]
            },
            "exit_mapping": {
                "0": "ok",
                "1": "finding",
                "2": "error",
                "3": "error"
            }
        },
