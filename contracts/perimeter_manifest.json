{
    "schema_version": "0.1.1",
    "manifest_name": "vectaetos_perimeter_manifest",
    "status": "active_report_first_candidate",
    "location": "contracts/perimeter_manifest.json",
    "role": "deterministic guard command registry",
    "posture": "report-first visibility manifest; not a canonical ontology source",
    "runner_policy": {
        "runner_has_semantic_authority": false,
        "runner_may_modify_files": false,
        "runner_may_suppress_findings": false,
        "runner_may_execute_only_manifest_commands": true,
        "guard_order_is_deterministic": true,
        "report_first": true,
        "strict_ci_blocking_enabled": false
    },
    "variables": {
        "ROOT": ".",
        "BASE_SHA": "HEAD~1",
        "HEAD_SHA": "HEAD",
        "PYTHON": "python3",
        "CODE_CONTRACT": "contracts/vectaetos_code_contract.json",
        "GUARD13_CONTRACT": "contracts/guard13_ek_observable_rules.json",
        "LICENSE_REGISTRY": "contracts/LICENSE_REGISTRY.json",
        "VECTOR_DRIFT_FAIL_AT": "0.70"
    },
    "exit_policy": {
        "guard_exit_0": "ok",
        "guard_exit_1": "finding_or_policy_failure",
        "guard_exit_2": "execution_or_configuration_error",
        "guard_exit_3": "contract_or_manifest_error_when_used_by_guard",
        "runner_exit_0": "report_first_completed_without_required_guard_error",
        "runner_exit_1": "one_or_more_required_guards_reported_findings",
        "runner_exit_2": "one_or_more_required_guards_failed_to_execute",
        "runner_exit_3": "manifest_or_runner_error",
        "note": "In this report-first manifest, active guards are intentionally non-required until the perimeter is calibrated. Findings and guard errors remain visible in the runner report."
    },
    "profiles": {
        "report": {
            "description": "non-blocking local visibility profile",
            "default_exit_mapping": {
                "0": "ok",
                "1": "finding",
                "2": "error",
                "3": "error"
            }
        },
        "ci": {
            "description": "report-first CI visibility profile; guard findings are visible but the runner does not block until required=true is promoted per guard",
            "default_exit_mapping": {
                "0": "ok",
                "1": "finding",
                "2": "error",
                "3": "error"
            }
        }
    },
